// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ARTIST
}

enum AssetType {
  TRACK
  LOOP
  SAMPLE
}

enum LicenseCode {
  PERSONAL
  COMMERCIAL
  UNLIMITED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  displayName  String
  role         UserRole @default(USER)

  assets       Asset[]
  purchases    Purchase[]
  
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id          String    @id @default(uuid())
  title       String
  description String?
  type        AssetType
  genre       String?

  bpm         Int?
  musicalKey  String?
  durationSec Int?

  fileUrl    String
  previewUrl String?
  coverUrl   String?

  artistId String
  artist   User   @relation(fields: [artistId], references: [id])

  licenses  AssetLicense[]
  purchases Purchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([artistId])
  @@index([type])
}

model License {
  id          String      @id @default(uuid())
  code        LicenseCode @unique
  name        String
  description String?

  assets    AssetLicense[]
  purchases Purchase[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AssetLicense {
  id         String @id @default(uuid())
  assetId    String
  licenseId  String
  priceCents Int
  description String?

  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  license License @relation(fields: [licenseId], references: [id])

  @@unique([assetId, licenseId])
  @@index([assetId])
  @@index([licenseId])
}

model Purchase {
  id         String @id @default(uuid())
  buyerId    String
  assetId    String
  licenseId  String
  priceCents Int

  buyer   User    @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  license License @relation(fields: [licenseId], references: [id])

  createdAt DateTime @default(now())

  @@index([buyerId])
  @@index([assetId])
  @@index([licenseId])
}

model Message {
  id         String   @id @default(uuid())
  text       String
  senderId   String
  receiverId String
  createdAt  DateTime @default(now())
  isRead     Boolean  @default(false)

  sender   User @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
}
